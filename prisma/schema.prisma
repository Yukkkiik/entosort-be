// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  superadmin
  admin
  peternak
}

enum NodeType {
  esp32
  raspberry
}

enum NodeStatus {
  online
  offline
}

enum ErrorSeverity {
  low
  medium
  high
  critical
}

enum TriggerSource {
  ir_sensor // ESP32 mendeteksi larva/prepupa lewat IR -> trigger kamera RPi
  manual    // dipicu manual dari dashboard
}

// ================================
// USER
// ================================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      UserRole @default(peternak)
  phone     String?  @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUnits   Unit[]       @relation("UnitAdmin")
  peternakUnit Unit?        @relation("UnitPeternak")
  harvestLogs  HarvestLog[]

  @@map("users")
}

// ================================
// UNIT -- satu alat fisik (1 ESP32 + 1 RPi)
// ================================
model Unit {
  id        Int        @id @default(autoincrement())
  unitId    String     @unique @db.VarChar(50)
  adminId   Int?
  peterId   Int?       @unique // 1 peternak hanya boleh 1 unit
  location  String?    @db.VarChar(100)
  status    NodeStatus @default(offline)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  admin    User? @relation("UnitAdmin",    fields: [adminId], references: [id], onDelete: SetNull)
  peternak User? @relation("UnitPeternak", fields: [peterId], references: [id], onDelete: SetNull)

  nodes       Node[]
  settings    Settings?
  sensorLogs  SensorLog[]
  harvestLogs HarvestLog[]
  errorLogs   ErrorLog[]

  @@map("units")
}

// ================================
// NODE -- hardware ESP32 atau Raspberry Pi
// ================================
model Node {
  id        Int        @id @default(autoincrement())
  nodeId    String     @unique @db.VarChar(50)
  unitId    String     @db.VarChar(50)
  nodeType  NodeType
  ipAddress String?    @db.VarChar(45)
  status    NodeStatus @default(offline)
  firmware  String?    @db.VarChar(50)
  lastSeen  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  unit       Unit        @relation(fields: [unitId], references: [unitId], onDelete: Cascade)
  sensorLogs SensorLog[] // hanya ESP32 yang punya sensorLogs

  @@unique([unitId, nodeType]) // tiap unit: 1 esp32 + 1 raspberry
  @@index([unitId])
  @@map("nodes")
}

// ================================
// SETTINGS -- konfigurasi per unit
// ESP32 baca: irThreshold, motor, solenoid
// RPi baca: HSV
// ================================
model Settings {
  id     Int    @id @default(autoincrement())
  unitId String @unique @db.VarChar(50)

  // RPi (computer vision)
  hsvLowerH Int @default(0)
  hsvLowerS Int @default(0)
  hsvLowerV Int @default(0)
  hsvUpperH Int @default(179)
  hsvUpperS Int @default(255)
  hsvUpperV Int @default(255)

  // ESP32 (aktuator + IR)
  irThreshold     Int     @default(500)
  motorSpeedRpm   Int     @default(100)
  solenoidDelayMs Int     @default(200)
  manualMode      Boolean @default(false)
  motorOn         Boolean @default(false)
  solenoidOn      Boolean @default(false)

  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [unitId], onDelete: Cascade)

  @@map("settings")
}

// ================================
// SENSOR LOG -- dari ESP32
// nodeId  : sumber hardware spesifik (untuk audit/debug)
// unitId  : untuk filter dashboard tanpa join
// ================================
model SensorLog {
  id          Int      @id @default(autoincrement())
  nodeId      String   @db.VarChar(50) // ESP32 yang mengirim
  unitId      String   @db.VarChar(50) // unit pemilik (denormalized, untuk query dashboard)
  temperature Float
  humidity    Float
  pressure    Float
  recordedAt  DateTime @default(now())

  node Node @relation(fields: [nodeId], references: [nodeId], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [unitId], onDelete: Cascade)

  @@index([nodeId])
  @@index([unitId])
  @@index([recordedAt])
  @@map("sensor_logs")
}

// ================================
// HARVEST LOG -- hasil AI dari RPi
// ================================
model HarvestLog {
  id            Int           @id @default(autoincrement())
  unitId        String        @db.VarChar(50)
  userId        Int?
  larvaCount    Int           @default(0)
  prepupaCount  Int           @default(0)
  rejectCount   Int           @default(0)
  totalCount    Int           @default(0)
  durationSec   Int?
  triggerSource TriggerSource @default(ir_sensor)
  notes         String?       @db.Text
  recordedAt    DateTime      @default(now())

  unit Unit  @relation(fields: [unitId], references: [unitId], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([unitId])
  @@index([recordedAt])
  @@map("harvest_logs")
}

// ================================
// ERROR LOG -- bisa dari ESP32 atau RPi
// ================================
model ErrorLog {
  id         Int           @id @default(autoincrement())
  unitId     String        @db.VarChar(50)
  nodeType   NodeType?     // node mana yang error (null = error level unit)
  errorCode  String?       @db.VarChar(50)
  errorType  String        @db.VarChar(100)
  message    String        @db.Text
  severity   ErrorSeverity @default(medium)
  resolved   Boolean       @default(false)
  occurredAt DateTime      @default(now())

  unit Unit @relation(fields: [unitId], references: [unitId], onDelete: Cascade)

  @@index([unitId])
  @@index([resolved])
  @@map("error_logs")
}
